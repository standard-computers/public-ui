# Runtime selection
APP_RUNTIME=server
MODE=

# Standalone demo runtime (used when MODE=demo)
DEMO_FIXTURE_PATH=
DEMO_SESSION_TTL_MS=7200000
DEMO_MAX_SESSIONS=50

# Web server / websocket runtime
PORT=80
STD_SYS_PORT=9002
CPP_WS_URL=
TIMEOUT=60000
ALLOWED_ORIGINS=
LOCAL_HOSTNAME=standard
FORCE_LOGIN=

# Relay / hosted deployment
STANDARD_CHIT=
RELAY_COOKIE_DOMAIN=
RELAY_COOKIE_SECRET=
RELAY_COOKIE_SECRETS=
RELAY_SETTINGS_COOKIE_PREFIX=relay_settings_

# HTTPS certs for relay / hosted installs
SSL_CERT_PATH=
SSL_KEY_PATH=

# Desktop app options
ELECTRON_START_URL=
ELECTRON_WINDOW_WIDTH=1440
ELECTRON_WINDOW_HEIGHT=960
ELECTRON_MIN_WIDTH=1024
ELECTRON_MIN_HEIGHT=720
ELECTRON_START_MAXIMIZED=false
ELECTRON_OPEN_DEVTOOLS=false

# Optional APIs
OPENWEATHER_API_KEY=
MAPBOX_ACCESS_TOKEN=
