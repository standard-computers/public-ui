<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>Login</title>
        <link href="/root.css" rel="stylesheet"/>
        <link href="/style.css" rel="stylesheet"/>
    </head>
    <body>
        <div class="padded guttered">
            <h1>Login</h1>
            <form method="POST" action="/login" id="login-form">
                <label for="username">Username</label>
                <input id="username" name="username" type="text" autocomplete="username" placeholder="Username" autofocus required/>
                <button type="submit" id="click-me">Continue</button>
                {{#if error}}
                <div class="error" id="login-error">{{error}}</div>
                {{/if}}
                <div id="retry-status" class="error" style="display:none"></div>
            </form>
        </div>
        <script>
        !function(){
            let e=document.cookie.match(/(?:^|;\s*)loginUsername=([^;]+)/);
            if(!e)return;
            try{
                let t=decodeURIComponent(e[1]),
                    n=document.getElementById("username");
                if(t&&n)n.value=t;
            }catch(l){}
        }();
        !function(){
            let e=document.getElementById("login-form"),
                t=document.getElementById("username"),
                n=document.getElementById("click-me"),
                o=document.getElementById("login-error"),
                r=document.getElementById("retry-status");
            if(!e||!t||!n)return;
            function i(e){
                if(!r)return;
                r.style.display=e?"block":"none";
                r.textContent=e||"";
            }
            e.addEventListener("submit",async function(a){
                a.preventDefault();
                let s=t.value.trim();
                if(!s){
                    i("Username is required");
                    return;
                }
                n.disabled=!0;
                i("Signing in...");
                if(o)o.style.display="none";
                try{
                    let l=new URLSearchParams;
                    l.set("username",s);
                    let c=await fetch(e.action,{
                        method:"POST",
                        headers:{
                            "Accept":"application/json",
                            "Content-Type":"application/x-www-form-urlencoded;charset=UTF-8",
                            "X-Requested-With":"XMLHttpRequest"
                        },
                        body:l.toString(),
                        credentials:"same-origin"
                    });
                    let d=c.headers.get("content-type")||"",
                        u=d.includes("application/json")?await c.json():null;
                    if(c.ok&&u&&u.redirect){
                        window.location.assign(u.redirect);
                        return;
                    }
                    i((u&&u.error)||"Unable to login");
                }catch(l){
                    i("Unable to login");
                }finally{
                    n.disabled=!1;
                }
            });
        }();
        </script>
    </body>
</html>
