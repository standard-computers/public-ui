{
  "name": "public-ui",
  "version": "1.0.0",
  "description": "",
  "main": "electron-main.js",
  "scripts": {
    "start": "node index.js",
    "start:web": "node index.js",
    "start:desktop": "cross-env APP_RUNTIME=electron electron electron-main.js",
    "build:desktop": "electron-builder --dir",
    "dist:desktop": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/standard-computers/public-ui.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/standard-computers/public-ui/issues"
  },
  "homepage": "https://github.com/standard-computers/public-ui#readme",
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-handlebars": "^8.0.3",
    "multer": "^2.0.2",
    "socket.io": "^4.8.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "net.standardcomputers.publicui",
    "productName": "Public UI",
    "files": [
      "electron-main.js",
      "index.js",
      "preload.js",
      "package.json",
      "public/**/*",
      "views/**/*"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "public/appicon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/appicon.png"
    }
  }
}
